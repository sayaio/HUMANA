# Template environment variables backend Humana.
# Salin file ini menjadi ".env" lalu isi nilainya. JANGAN commit file .env yang asli.
# Di Render, isi nilai-nilai ini lewat menu "Environment".

DB_PASSWORD=
MIDTRANS_SERVER_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sertifikat CA Aiven (isi untuk deployment di Render — paste seluruh isi file ca.pem).
# Untuk development lokal, kosongkan saja karena backend akan membaca file ca.pem.
AIVEN_CA_CERT=
